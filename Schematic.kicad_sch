			)
			(justify left top)
		)
		(uuid "320070fc-76d8-4495-8005-74016151a1cf")
	)
	(text_box "1) R4 limits the max. output voltage to approximately 545 V\n\n2) VR1 + R4 allow adjusting the output voltage down to approximately 169 V\n\n3) To bypass primary side error amplifier:\na) fit R33 (0R)\nb) update R12 to 0R\nc) remove R2, R3, R28, R29, R32, C2 and C25\n\n4) Populate D8 if connecting output of multiple modules in series\n\n5) Estimated specs for reused (and unmarked) parts:\na) R9: ~13.7 mΩ (110 mV @ 8.04 A)\nb) TR1: ~1:19.5 turns ratio, 3.54:1453 uH "
		(exclude_from_sim no)
		(at 20.32 177.8 0)
		(size 66.04 66.04)
		(margins 2 2 2 2)
		(stroke
			(width 0.508)
			(type solid)
			(color 132 132 132 1)
		)
		(fill
			(type color)
			(color 200 200 200 1)
		)
		(effects
			(font
				(face "Arial")
				(size 2 2)
				(color 0 0 0 1)
			)
			(justify left top)
		)
		(uuid "49614465-5ccc-49f1-84fd-625a39b1cda9")
	)
