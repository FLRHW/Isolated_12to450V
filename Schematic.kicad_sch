	(text_box "6) Consider using TL432 if replacing ${/f9e05184-c88b-4a88-ae9c-ab2bdb32be7c/82da9dbf-ba38-4d08-ba35-a220fa2963b1/b0fdce11-0fa7-4399-9147-4b60eb490e1b/ad4dd466-39da-4dc2-a3ca-59acd44d0e72:Reference} as the selected part does not use the standard TL431 pinout."
		(exclude_from_sim no)
		(at 20.32 254 0)
		(size 66.04 15.24)
		(margins 2 2 2 2)
		(stroke
			(width 0.508)
			(type solid)
			(color 239 214 0 1)
		)
		(fill
			(type color)
			(color 250 247 201 1)
		)
		(effects
			(font
				(face "Arial")
				(size 2 2)
