# https://kibot.readthedocs.io/en/latest/configuration/outputs/kiri.html

kibot:
  version: 1

outputs:
- name: html_kiri
  comment: 'KiRI webpage'
  type: kiri
  category: 'KiRI'
  dir: 'KiRI'
  layers: all
  options:
    keep_generated: true
    max_commits: 3
    revision: 'HEAD'
    zones: 'global'

